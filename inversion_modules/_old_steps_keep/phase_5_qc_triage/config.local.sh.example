# =============================================================================
# config.local.sh — site-local overrides for phase_qc_shelf on LANTA
# =============================================================================
# Sourced by 00_config.sh (which sources this first, then sets defaults).
# Also sourced directly by debug/rerun commands so BASE / UNIFIED_ANCESTRY_DIR
# etc. are available in the user's shell.
#
# Edit the top block (anchor + repo roots) for a different HPC; everything
# below derives from those.
# =============================================================================

# ---- 1. Anchor paths --------------------------------------------------------
export BASE="/path/to/your/project/base"  # e.g., /scratch/lt200308-agbsci/Quentin_project_KEEP_2026-02-04
REPO_ROOT="${BASE}/inversion-popgen-toolkit"

# ---- 2. Source the shared inversion pipeline config -------------------------
# This sets HETDIR, SAMPLES_IND, BEAGLE_DIR, PRECOMP_DIR, K_SWEEP, etc.
# for the wider 28-chromosome pipeline.
if [[ -f "${REPO_ROOT}/inversion_modules/00_inversion_config.sh" ]]; then
  source "${REPO_ROOT}/inversion_modules/00_inversion_config.sh"
fi

# ---- 3. Name translations ---------------------------------------------------
# The shared config uses some different variable names than phase_qc_shelf.
# Bridge them here so both downstream users see consistent names.
export HET_DIR="${HETDIR}"
export SAMPLE_LIST="${SAMPLES_IND}"
export SAMPLE_LIST_POPSTATS="${SAMPLES_IND}"

# ---- 4. Overrides that matter for this module ------------------------------
# Use the DENSE local-PCA BEAGLE (not the popstruct_thin BEAGLE). This is
# the BEAGLE that Q02 (BEAGLE uncertainty) and Q08 (heatmap) stream. The
# multi-scale Engine B precompute pulls BOTH thin and dense automatically.
export BEAGLE_DIR="${BASE}/inversion_localpca_v7/02_snps_beagle"

# Point at the unified_ancestry that lives INSIDE the repo (not a sibling at
# ${BASE}/unified_ancestry, which some older code assumes).
export UNIFIED_ANCESTRY_DIR="${REPO_ROOT}/unified_ancestry"
export LOCAL_Q_DIR="${UNIFIED_ANCESTRY_DIR}/local_Q"

# Pin the Engine B binary to the repo-local build. The unified_ancestry
# config file will try to overwrite INSTANT_Q_BIN to its own assumed path;
# STEP_Q06_precompute.sh stashes this and restores it after sourcing. But
# having it pinned here is the belt-and-braces fix.
export INSTANT_Q_BIN="${UNIFIED_ANCESTRY_DIR}/src/instant_q"

# Engine F binary. Compiled by install.sh.
export REGION_POPSTATS_BIN="${UNIFIED_ANCESTRY_DIR}/engines/fst_dxy/region_popstats"

# ---- 5. Typical per-run knobs (override at the bash invocation if needed) --
# Q06 ancestry precompute sweep:
#   Default: K=8 only, thin+dense. Set Q06_K_SWEEP="4,8,10,14" to get 4 Ks.
# : "${Q06_K_SWEEP:=8}"
# : "${Q06_SCALES:=thin,dense}"

# Q04 snp density scale: 1 = SNPs/kb, 10 = SNPs/10kb, 50 = SNPs/50kb
# : "${SNP_DENSITY_SCALE_KB:=10}"
