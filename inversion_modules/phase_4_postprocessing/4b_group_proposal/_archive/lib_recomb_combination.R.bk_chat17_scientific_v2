#!/usr/bin/env Rscript
# =============================================================================
# lib_recomb_combination.R — v12 (chat-12): DAG-based R derivation
# =============================================================================
# CHANGED in chat-12: derive_R_from_regime() now builds a minimal directed
# graph per sample from the per-window regime labels and returns a rich
# per-sample + cohort summary (see regime_sample_dag.schema.json). R_fired
# is now a TWO-gate decision: deviation_fraction >= min_deviation_fraction
# AND longest_deviation_bp >= min_deviation_bp. The prior draft's
# "consecutive-long-segments-with-different-values" counter has been
# removed — it over-counted A->B->A patterns as 2 changes and was too
# rigid about shape. The DAG formulation is the one Quentin specified at
# end-of-chat-11.5.
#
# Everything else in this file (derive_B_from_local_structure,
# combine_sample_recomb, combine_cohort_recomb) is unchanged.
# =============================================================================
# This is the multi-recomb combination rule that consumes the outputs of the
# four signal producers:
#
#   R (recombinant) : C01j regime_memberships — sample's compatibility group
#                      membership changes across the candidate interval.
#                      This replaces the old per-SNP CUSUM and is the PRIMARY
#                      recombinant signal per chat-9 design.
#   B (boundary)    : C01l local_structure — per-segment delta12/ENA/entropy
#                      quantifies how sharp the boundary is. Very diffuse
#                      boundaries = many samples "soft-boundary".
#   G (GHSL split)  : lib_ghsl_confirmation — within-interval karyotype
#                      change (INV_INV run AND INV_nonINV run both present).
#   C (gene conv.)  : gene_conversion_detector — short (1–5 bin) dosage
#                      excursions. These are AUXILIARY: GC tracts are NOT
#                      recombinants; they get recorded per sample but don't
#                      gate the RECOMBINANT call.
#
# DECISION RULES for final per-sample classification:
#
#   R  AND G                                   → RECOMBINANT, HIGH
#   R  AND NOT G, G_resolution = insufficient  → RECOMBINANT, MEDIUM (regime_only)
#   R  AND NOT G, G_resolution = sufficient    → recomb_disputed (flag)
#   NOT R AND G                                → recomb_ghsl_only (flag)
#   NOT R AND NOT G                            → NOT_RECOMB
#                                                 (Tier-1 class from decompose stands)
#
#   Orthogonally, for every sample:
#     C > 0 AND R TRUE  → annotation "RECOMB + embedded GC tracts"
#     C > 0 AND R FALSE → annotation "GC-only" (not recombinant)
#     C == 0            → no GC annotation
#
# C and B are never in the gate path:
#   - C informs the annotation but doesn't upgrade or downgrade recomb status.
#   - B informs boundary_sharpness for the candidate (not per-sample), and
#     influences the VALIDATION confidence downstream (4c), not the recomb
#     decision in 4b.
#
# Auxiliary signals (Clair3 phase switches, sv_prior hemizygous) are
# recorded per sample for the per-sample record, not in the gate.
# =============================================================================

suppressPackageStartupMessages({
  library(data.table)
})

`%||%` <- function(a, b) if (is.null(a) || length(a) == 0) b else a

# =============================================================================
# Derive R (recombinant signal from C01j) per sample — DAG formulation
# =============================================================================
# C01j writes regime_memberships.tsv.gz with (chrom, pos_mid_mb, window_idx,
# sample, group_id, thickness, dosage_class).
#
# DAG semantics (chat-12, replaces the old consecutive-long-segments counter):
#
#   For each sample, take its sequence of per-window regime labels inside
#   the candidate interval and collapse consecutive duplicates via rle().
#   Each distinct run becomes a NODE, weighted by its window count. Each
#   transition between consecutive runs becomes an EDGE.
#
#   Per-sample summary:
#     n_windows              total windows for this sample in the interval
#     n_distinct_nodes       number of distinct regime labels visited
#     n_edges                n_distinct_runs - 1 (0 if only one run)
#     dominant_regime        argmax over summed run lengths (ties: first
#                              occurrence wins — rle gives a deterministic
#                              ordering)
#     dominant_run_windows   total windows in the dominant regime
#     deviation_fraction     1 - dominant_run_windows / n_windows
#     longest_deviation_windows
#                            length in windows of the longest contiguous
#                              non-dominant run (0 if none)
#     longest_deviation_bp   longest_deviation_windows * window_size_bp
#     terminal_matches_start rle$values[1] == rle$values[length(rle$values)]
#     R_fired                deviation_fraction >= min_deviation_fraction
#                              AND longest_deviation_bp >= min_deviation_bp
#
#   Cohort summary:
#     n_samples_total, n_samples_with_deviation, fraction_samples_deviating,
#     n_samples_R_fired, fraction_samples_R_fired,
#     dominant_regime_cohort (mode of per-sample dominants),
#     dominant_regime_support (fraction of samples whose dominant matches
#     the cohort mode).
#
# Why these and not the old counter:
#   * A-A-A-B-B-A under the old counter yielded 2 changes (A->B, B->A); here
#     it yields deviation_fraction = 2/6 = 0.33 and longest_deviation_windows
#     = 2. The scalar deviation_fraction doesn't inflate with each swing
#     back to dominant.
#   * A-A-A-B-A-B-B-A (alternating noise) under the old counter threw away
#     the singleton B's (min_run=3 dropped them), so it undercounted; here,
#     no short-burst filter exists — short bursts just contribute their
#     windows to deviation_fraction, and R_fired ultimately protects
#     against singleton noise via the longest_deviation_bp gate.
#   * terminal_matches_start is weak additional evidence: noise tends to
#     return to dominant (start==end), a true recombinant at the edge of
#     an interval often does NOT (start!=end). Recorded but not in the
#     gate.
#
# Inputs:
#   regime_memb: data.table from regime_memberships.tsv.gz. Expected cols:
#                  sample (or sample_id), pos_mid_mb (or pos_mb), group_id.
#   interval:    list(start_mb,end_mb) or list(start_bp,end_bp).
#   min_deviation_fraction: R_fired gate on the scalar (default 0.15).
#   min_deviation_bp:       R_fired gate on the longest-deviation bp span
#                             (default 50000).
#   window_size_bp:         size of one window in bp; used to map
#                             longest_deviation_windows -> bp. If NULL, we
#                             infer from the median diff of pos_mid_mb
#                             values in the input (converted to bp).
#
# Returns a LIST with components:
#   per_sample (data.table): one row per sample with the DAG fields above,
#                              plus R_fired and the legacy n_regime_changes
#                              column (now defined as n_edges) so existing
#                              callers that select $R_fired / $n_regime_changes
#                              keep working.
#   cohort     (list):       cohort-level aggregates.
#   params     (list):       reproducibility record.
#
# For back-compat with call sites that do `r_dt <- derive_R_from_regime(...)`
# and then iterate rows, we ALSO set class(out) <- c("regime_dag","list") —
# callers can use is.data.table() checks to adapt. combine_cohort_recomb()
# has been verified to use r_dt$R_fired and r_dt$n_regime_changes, which
# are both present on the per_sample data.table. A back-compat unwrapper
# (as.data.table on the returned list) is offered via a generic below.
# =============================================================================
derive_R_from_regime <- function(regime_memb, interval,
                                    min_deviation_fraction = 0.15,
                                    min_deviation_bp       = 50000L,
                                    window_size_bp         = NULL) {

  empty_result <- function() {
    structure(list(
      per_sample = data.table(
        sample_id                 = character(),
        n_windows                 = integer(),
        n_distinct_nodes          = integer(),
        n_edges                   = integer(),
        dominant_regime           = character(),
        dominant_run_windows      = integer(),
        deviation_fraction        = numeric(),
        longest_deviation_windows = integer(),
        longest_deviation_bp      = integer(),
        terminal_matches_start    = logical(),
        R_fired                   = logical(),
        n_regime_changes          = integer(),
        dag_nodes_compact         = character(),
        dag_node_weights          = list()
      ),
      cohort = list(
        n_samples_total            = 0L,
        n_samples_with_deviation   = 0L,
        fraction_samples_deviating = 0,
        n_samples_R_fired          = 0L,
        fraction_samples_R_fired   = 0,
        dominant_regime_cohort     = NA_character_,
        dominant_regime_support    = NA_real_
      ),
      params = list(
        min_deviation_fraction = min_deviation_fraction,
        min_deviation_bp       = as.integer(min_deviation_bp),
        window_size_bp         = if (is.null(window_size_bp)) NA_integer_
                                 else as.integer(window_size_bp)
      )
    ), class = c("regime_dag","list"))
  }

  if (is.null(regime_memb) || !is.data.table(regime_memb) ||
      nrow(regime_memb) == 0) {
    return(empty_result())
  }

  # ── Normalise column names (sample vs sample_id, pos_mid_mb vs pos_mb) ──
  rm <- copy(regime_memb)
  if (!"sample" %in% names(rm) && "sample_id" %in% names(rm)) {
    setnames(rm, "sample_id", "sample")
  }
  pos_col <- if ("pos_mid_mb" %in% names(rm)) "pos_mid_mb"
             else if ("pos_mb"  %in% names(rm)) "pos_mb"
             else NA_character_
  if (is.na(pos_col)) {
    warning("[combination] regime_memb has no pos_mid_mb/pos_mb column")
    return(empty_result())
  }
  if (!"group_id" %in% names(rm) || !"sample" %in% names(rm)) {
    warning("[combination] regime_memb missing sample or group_id column")
    return(empty_result())
  }

  # ── Interval in Mb ──
  s_mb <- interval$start_mb %||% (interval$start_bp / 1e6)
  e_mb <- interval$end_mb   %||% (interval$end_bp   / 1e6)
  if (is.null(s_mb) || is.null(e_mb) || is.na(s_mb) || is.na(e_mb)) {
    warning("[combination] interval missing start/end")
    return(empty_result())
  }

  rm_in <- rm[get(pos_col) >= s_mb & get(pos_col) <= e_mb]
  if (nrow(rm_in) == 0) return(empty_result())

  # ── Infer window size (bp) if not supplied ──
  if (is.null(window_size_bp) || is.na(window_size_bp) || window_size_bp <= 0) {
    pos_vals <- sort(unique(rm_in[[pos_col]]))
    if (length(pos_vals) >= 2L) {
      window_size_bp <- as.integer(round(median(diff(pos_vals)) * 1e6))
    } else {
      window_size_bp <- 0L  # length-1 track; bp cannot be inferred
    }
  } else {
    window_size_bp <- as.integer(window_size_bp)
  }

  setorderv(rm_in, c("sample", pos_col))

  # ── Per-sample DAG ──
  per_sample <- rm_in[, {
    grp <- as.character(group_id)
    grp <- grp[!is.na(grp)]
    n_w <- length(grp)
    if (n_w == 0L) {
      # No informative windows
      list(
        n_windows                 = 0L,
        n_distinct_nodes          = 0L,
        n_edges                   = 0L,
        dominant_regime           = NA_character_,
        dominant_run_windows      = 0L,
        deviation_fraction        = 0,
        longest_deviation_windows = 0L,
        longest_deviation_bp      = 0L,
        terminal_matches_start    = NA,
        R_fired                   = FALSE,
        n_regime_changes          = 0L,
        dag_nodes_compact         = NA_character_,
        dag_node_weights          = list(integer(0))
      )
    } else {
      r <- rle(grp)
      run_labels  <- r$values
      run_lengths <- r$lengths
      # Dominant label = argmax of summed run lengths; ties -> first-seen.
      # tapply() returns in alphabetical order; to keep first-seen ties,
      # we use factor with levels = unique(run_labels).
      lv <- unique(run_labels)
      per_label_windows <- vapply(lv, function(L) {
        sum(run_lengths[run_labels == L])
      }, integer(1))
      dom_idx <- which.max(per_label_windows)
      dom <- lv[dom_idx]
      dom_w <- per_label_windows[dom_idx]

      dev_frac <- 1 - dom_w / n_w

      # Longest contiguous non-dominant run
      non_dom_mask <- run_labels != dom
      longest_dev_w <- if (any(non_dom_mask)) max(run_lengths[non_dom_mask]) else 0L
      longest_dev_bp <- as.integer(longest_dev_w) *
                         as.integer(window_size_bp %||% 0L)

      n_distinct <- length(lv)
      n_edges    <- length(run_labels) - 1L
      term_match <- run_labels[1L] == run_labels[length(run_labels)]

      R_fired <- (dev_frac >= min_deviation_fraction) &
                 (longest_dev_bp >= min_deviation_bp)

      list(
        n_windows                 = as.integer(n_w),
        n_distinct_nodes          = as.integer(n_distinct),
        n_edges                   = as.integer(n_edges),
        dominant_regime           = as.character(dom),
        dominant_run_windows      = as.integer(dom_w),
        deviation_fraction        = as.numeric(dev_frac),
        longest_deviation_windows = as.integer(longest_dev_w),
        longest_deviation_bp      = as.integer(longest_dev_bp),
        terminal_matches_start    = as.logical(term_match),
        R_fired                   = as.logical(R_fired),
        # Back-compat alias: old callers read n_regime_changes; we map it
        # to n_edges (the number of transitions between consecutive runs).
        n_regime_changes          = as.integer(n_edges),
        dag_nodes_compact         = paste(run_labels, collapse = "->"),
        dag_node_weights          = list(as.integer(run_lengths))
      )
    }
  }, by = sample]
  setnames(per_sample, "sample", "sample_id")

  # ── Cohort aggregates ──
  n_tot <- nrow(per_sample)
  n_dev <- sum(per_sample$deviation_fraction > 0, na.rm = TRUE)
  n_R   <- sum(per_sample$R_fired, na.rm = TRUE)

  # Cohort dominant regime = mode of per-sample dominants (ignoring NA)
  dom_tbl <- sort(table(per_sample$dominant_regime), decreasing = TRUE)
  if (length(dom_tbl) > 0L) {
    cohort_dom <- names(dom_tbl)[1L]
    dom_support <- as.numeric(dom_tbl[1L] / n_tot)
  } else {
    cohort_dom <- NA_character_
    dom_support <- NA_real_
  }

  cohort <- list(
    n_samples_total            = as.integer(n_tot),
    n_samples_with_deviation   = as.integer(n_dev),
    fraction_samples_deviating = if (n_tot) as.numeric(n_dev / n_tot) else 0,
    n_samples_R_fired          = as.integer(n_R),
    fraction_samples_R_fired   = if (n_tot) as.numeric(n_R / n_tot) else 0,
    dominant_regime_cohort     = cohort_dom,
    dominant_regime_support    = dom_support
  )

  params <- list(
    min_deviation_fraction = as.numeric(min_deviation_fraction),
    min_deviation_bp       = as.integer(min_deviation_bp),
    window_size_bp         = as.integer(window_size_bp %||% 0L)
  )

  structure(list(per_sample = per_sample, cohort = cohort, params = params),
            class = c("regime_dag","list"))
}

# =============================================================================
# Back-compat: if a caller still expects a data.table with (sample_id,
# R_fired, n_regime_changes, ...), unwrap via as_regime_dt(). Existing
# combine_cohort_recomb() uses r_dt$sample_id / $R_fired / $n_regime_changes;
# this helper lets call sites that haven't been updated yet do:
#   r_res <- derive_R_from_regime(...); r_dt <- as_regime_dt(r_res)
# and keep working while we migrate them.
# =============================================================================
as_regime_dt <- function(x) {
  if (is.data.table(x)) return(x)
  if (is.list(x) && !is.null(x$per_sample) && is.data.table(x$per_sample)) {
    return(x$per_sample)
  }
  data.table(sample_id = character(), R_fired = logical(),
             n_regime_changes = integer())
}

# =============================================================================
# Derive B (boundary sharpness) from C01l per-segment metrics
# =============================================================================
# C01l writes segment_summary.tsv.gz with (candidate_id, segment,
# mean_delta12, mean_entropy, mean_ena).
# For a candidate, compare flank vs core:
#   inv_core.mean_delta12 should be HIGH (one dominant local background)
#   left_flank/right_flank.mean_delta12 can be lower (more heterogeneous)
#
# A SHARP boundary: flank.delta12 is very different from core.delta12.
# A DIFFUSE boundary: half-region (inv_left_half) has delta12 intermediate.
#
# Returns a named list with per-candidate boundary sharpness metrics:
#   core_delta12, left_half_delta12, right_half_delta12,
#   left_flank_delta12, right_flank_delta12,
#   left_sharpness, right_sharpness, overall_sharpness.
# =============================================================================
derive_B_from_local_structure <- function(c01l_summary, cid,
                                             diffuse_thresh = 0.15,
                                             sharp_thresh = 0.35) {
  if (is.null(c01l_summary) || !is.data.table(c01l_summary) ||
      nrow(c01l_summary) == 0) return(NULL)
  rows <- c01l_summary[candidate_id == cid]
  if (nrow(rows) == 0) return(NULL)

  get_d12 <- function(seg) {
    r <- rows[segment == seg]
    if (nrow(r) == 0) NA_real_ else r$mean_delta12[1]
  }

  core_d12         <- get_d12("inv_core")
  left_flank_d12   <- get_d12("left_flank")
  right_flank_d12  <- get_d12("right_flank")
  left_half_d12    <- get_d12("inv_left_half")
  right_half_d12   <- get_d12("inv_right_half")

  # Sharp if core >> flank AND left_half ≈ core
  left_sharpness <- if (is.na(core_d12) || is.na(left_flank_d12)) NA_character_
  else {
    diff_lf <- core_d12 - left_flank_d12
    if (diff_lf >= sharp_thresh) "sharp"
    else if (diff_lf >= diffuse_thresh) "moderate"
    else "diffuse"
  }
  right_sharpness <- if (is.na(core_d12) || is.na(right_flank_d12)) NA_character_
  else {
    diff_rf <- core_d12 - right_flank_d12
    if (diff_rf >= sharp_thresh) "sharp"
    else if (diff_rf >= diffuse_thresh) "moderate"
    else "diffuse"
  }

  overall <- if (is.na(left_sharpness) && is.na(right_sharpness)) NA_character_
  else if (isTRUE(left_sharpness == "sharp") && isTRUE(right_sharpness == "sharp")) "sharp"
  else if (isTRUE(left_sharpness == "diffuse") && isTRUE(right_sharpness == "diffuse")) "diffuse"
  else if ((isTRUE(left_sharpness == "sharp") && isTRUE(right_sharpness == "diffuse")) ||
           (isTRUE(left_sharpness == "diffuse") && isTRUE(right_sharpness == "sharp"))) "asymmetric"
  else "moderate"

  list(
    candidate_id       = cid,
    core_delta12       = core_d12,
    left_flank_delta12  = left_flank_d12,
    right_flank_delta12 = right_flank_d12,
    left_half_delta12   = left_half_d12,
    right_half_delta12  = right_half_d12,
    left_sharpness      = left_sharpness,
    right_sharpness     = right_sharpness,
    overall_sharpness   = overall
  )
}

# =============================================================================
# Combine R + G (gate path) with annotations from C + B + auxiliaries
# =============================================================================
combine_sample_recomb <- function(r_row, g_row,
                                     g_resolution = "no_annot",
                                     gc_row = NULL,
                                     auxiliary = list()) {
  R <- isTRUE(r_row$R_fired %||% FALSE)
  G <- isTRUE((g_row$ghsl_call %||% "UNINFORMATIVE") == "SPLIT")
  gcall <- as.character(g_row$ghsl_call %||% "UNINFORMATIVE")

  out <- list(
    recomb_status      = "NOT_RECOMB",
    confidence         = "n/a",
    R_fired            = R,
    G_fired            = G,
    ghsl_call          = gcall,
    ghsl_resolution    = g_resolution,
    n_regime_changes   = r_row$n_regime_changes %||% 0L,
    n_gc_tracts        = gc_row$n_tracts %||% 0L,
    gc_tract_widths_bp = gc_row$tract_widths_bp %||% integer(0),
    s2_phase_switches  = auxiliary$s2 %||% NA,
    s3_flashlight_hemi = auxiliary$s3 %||% NA,
    flag               = NA_character_,
    annotation         = NA_character_
  )

  if (R && G) {
    out$recomb_status <- "RECOMBINANT"
    out$confidence    <- "HIGH"
  } else if (R && !G && g_resolution %in% c("insufficient", "no_annot")) {
    out$recomb_status <- "RECOMBINANT"
    out$confidence    <- "MEDIUM"
    out$flag          <- "regime_only_ghsl_insufficient"
  } else if (R && !G && g_resolution == "sufficient") {
    out$recomb_status <- "recomb_disputed"
    out$confidence    <- "DISPUTED"
    out$flag          <- paste0("regime_change_but_ghsl=", gcall)
  } else if (!R && G) {
    out$recomb_status <- "recomb_ghsl_only"
    out$confidence    <- "GHSL_ONLY"
    out$flag          <- "ghsl_split_but_no_regime_change"
  }
  # else: NOT_RECOMB; Tier-1 decompose class stands.

  # Orthogonal annotation from gene-conversion detector (does NOT gate)
  if ((gc_row$n_tracts %||% 0L) > 0L) {
    if (out$recomb_status == "RECOMBINANT") {
      out$annotation <- sprintf("RECOMB + %d GC tract(s)", gc_row$n_tracts)
    } else if (out$recomb_status == "NOT_RECOMB") {
      out$annotation <- sprintf("GC-only (%d tract(s))", gc_row$n_tracts)
    } else {
      out$annotation <- sprintf("%s + %d GC tract(s)", out$recomb_status, gc_row$n_tracts)
    }
  }

  out
}

# =============================================================================
# Cohort-wide combiner
# =============================================================================
# Inputs:
#   r_dt: data.table from derive_R_from_regime (sample_id, R_fired, ...)
#   g_dt: data.table from ghsl_per_sample_in_interval (sample_id, ghsl_call)
#   g_resolution: "sufficient" / "insufficient" / "no_annot"
#   gc_summary: data.table from detect_cohort_gene_conversion()$summary
#               (sample_id, n_tracts, flank_dosage, detector)
#   aux_dt: optional data.table(sample_id, s2_phase_switches,
#             s3_flashlight_hemi)
# =============================================================================
combine_cohort_recomb <- function(r_dt = NULL, g_dt = NULL,
                                      g_resolution = "no_annot",
                                      gc_summary = NULL,
                                      aux_dt = NULL,
                                      all_samples = NULL) {
  # Back-compat: derive_R_from_regime() now returns a list(per_sample, cohort,
  # params). Callers that haven't migrated yet may pass the whole list here
  # expecting the old data.table shape. Unwrap it transparently.
  if (!is.null(r_dt) && !is.data.table(r_dt) &&
      is.list(r_dt) && !is.null(r_dt$per_sample) &&
      is.data.table(r_dt$per_sample)) {
    r_dt <- r_dt$per_sample
  }

  # Union of sample IDs
  all_sids <- unique(c(
    if (!is.null(r_dt)) r_dt$sample_id else NULL,
    if (!is.null(g_dt)) g_dt$sample_id else NULL,
    if (!is.null(gc_summary)) gc_summary$sample_id else NULL,
    all_samples
  ))
  if (length(all_sids) == 0) return(data.table())

  r_map  <- if (!is.null(r_dt))  setNames(split(r_dt,  r_dt$sample_id),  r_dt$sample_id)  else list()
  g_map  <- if (!is.null(g_dt))  setNames(split(g_dt,  g_dt$sample_id),  g_dt$sample_id)  else list()
  gc_map <- if (!is.null(gc_summary))
              setNames(split(gc_summary, gc_summary$sample_id), gc_summary$sample_id)
            else list()
  aux_map <- if (!is.null(aux_dt))
               setNames(split(aux_dt, aux_dt$sample_id), aux_dt$sample_id)
             else list()

  rows <- lapply(all_sids, function(sid) {
    r_row <- if (!is.null(r_map[[sid]])) as.list(r_map[[sid]][1]) else list(R_fired = FALSE, n_regime_changes = 0L)
    g_row <- if (!is.null(g_map[[sid]])) as.list(g_map[[sid]][1]) else list(ghsl_call = "UNINFORMATIVE")
    gc_row <- if (!is.null(gc_map[[sid]])) as.list(gc_map[[sid]][1]) else list(n_tracts = 0L)
    aux <- if (!is.null(aux_map[[sid]])) {
      a <- as.list(aux_map[[sid]][1])
      list(s2 = a$s2_phase_switches %||% NA,
           s3 = a$s3_flashlight_hemi %||% NA)
    } else list()
    res <- combine_sample_recomb(r_row, g_row, g_resolution, gc_row, aux)
    c(list(sample_id = sid), res)
  })

  rbindlist(lapply(rows, function(r) {
    r$gc_tract_widths_bp <- list(r$gc_tract_widths_bp %||% integer(0))
    as.data.table(r)
  }), fill = TRUE)
}
