{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "internal_ancestry_composition.schema.json",
  "block_type": "internal_ancestry_composition",
  "version": "v1_phase4b_rewrite",
  "description": "Per-candidate internal ancestry structure classification. For each sample, walks the Engine B per-window ancestry labels inside the candidate interval and classifies the pattern as homogeneous, dominant_plus_secondary, two_block_composite, continuous_gradient, multi_block_fragmented, or diffuse_mixed. The per-candidate rollup derives composite_flag ∈ {clean, maybe_composite, likely_composite, unknown_no_engine_b}, which governs whether C01f can promote the candidate's groups to SUPPORTED/VALIDATED. This is the block that catches 'same interval, different sample groups' — composite intervals get flagged and capped at UNCERTAIN.",
  "question": "Q1, Q2",
  "group_validation_required": "NONE (group-independent — reads Engine B directly)",
  "source_script": "STEP_C01i_c_nested_composition.py",
  "required": ["parent_id", "chrom", "start_bp", "end_bp", "composite_flag"],
  "properties": {
    "parent_id":           { "type": "string", "description": "candidate_id of the parent interval" },
    "chrom":               { "type": "string" },
    "start_bp":            { "type": "integer" },
    "end_bp":              { "type": "integer" },
    "K_used":              { "type": "integer" },
    "n_samples_analyzed":  { "type": "integer" },
    "n_windows_in_parent": { "type": "integer" },
    "dominant_structure_type": {
      "type": "string",
      "enum": ["homogeneous", "dominant_plus_secondary", "two_block_composite",
               "continuous_gradient", "multi_block_fragmented", "diffuse_mixed",
               "too_sparse", "unknown"]
    },
    "dominant_structure_count": { "type": "integer" },
    "structure_breakdown":      { "type": "string", "description": "human-readable like 'homogeneous:120; two_block_composite:45'" },
    "structure_counts":         { "type": "object" },
    "mean_fragmentation":       { "type": "number" },
    "mean_internal_entropy":    { "type": "number" },
    "mean_switches":            { "type": "number" },
    "composite_flag": {
      "type": "string",
      "enum": ["clean", "maybe_composite", "likely_composite", "unknown_no_engine_b"],
      "description": "governs C01f promotion gating: likely_composite caps at UNCERTAIN, maybe_composite allows but logs, clean = no effect, unknown_no_engine_b = treat as clean + log"
    },
    "composite_rationale":        { "type": "string" },
    "pct_homogeneous_like":       { "type": "number" },
    "pct_two_block_composite":    { "type": "number" },
    "pct_multi_block_fragmented": { "type": "number" },
    "pct_continuous_gradient":    { "type": "number" },
    "pct_diffuse_mixed":          { "type": "number" },
    "per_sample": {
      "type": "array",
      "description": "one entry per sample; excluded if too few windows",
      "items": {
        "type": "object",
        "required": ["sample_id", "structure_type"],
        "properties": {
          "sample_id":          { "type": "string" },
          "n_windows":          { "type": "integer" },
          "n_labels_unique":    { "type": "integer" },
          "dominant_label":     { "type": "string" },
          "dominant_fraction":  { "type": "number" },
          "n_blocks":           { "type": "integer" },
          "n_switches":         { "type": "integer" },
          "largest_block":      { "type": "integer" },
          "second_block":       { "type": "integer" },
          "fragmentation_score":{ "type": "number" },
          "internal_entropy":   { "type": "number" },
          "structure_type":     { "type": "string" },
          "mean_delta12":       { "type": "number" },
          "mean_entropy":       { "type": "number" },
          "mean_ena":           { "type": "number" }
        }
      }
    }
  },
  "keys_extracted": [
    { "key": "q1_ancestry_composite_flag",   "from": "composite_flag" },
    { "key": "q1_ancestry_dominant_structure","from": "dominant_structure_type" },
    { "key": "q2_pct_samples_two_block",     "from": "pct_two_block_composite" },
    { "key": "q2_pct_samples_multi_block",   "from": "pct_multi_block_fragmented" },
    { "key": "q2_pct_samples_homogeneous",   "from": "pct_homogeneous_like" },
    { "key": "q2_pct_samples_gradient",      "from": "pct_continuous_gradient" },
    { "key": "q2_mean_fragmentation",        "from": "mean_fragmentation" },
    { "key": "q2_mean_internal_entropy",     "from": "mean_internal_entropy" },
    { "key": "q2_mean_switches",             "from": "mean_switches" }
  ]
}
