#!/usr/bin/env bash
#SBATCH -p compute
#SBATCH -N 1
#SBATCH -n 8
#SBATCH --mem=32G
#SBATCH -t 0-02:00:00
#SBATCH -J bpv_s01
#SBATCH -o logs/01_extract_candidates.%j.out
#SBATCH -e logs/01_extract_candidates.%j.err
# =============================================================================
# 01_extract_inv_candidates.sh — v2: dual-caller extraction
# =============================================================================
# Extracts INV candidates from BOTH DELLY2 and Manta, applies caller-specific
# quality filters, deduplicates overlapping calls, and matches to Snake
# inversion candidates.
#
# Output: unified candidate table with columns:
#   inv_id, chrom, bp1_pos, bp2_pos, svlen_bp, qual, pe, sr, precise, filter,
#   caller, caller_extra, snake_match, snake_candidate_id, snake_tier, snake_score
# =============================================================================
set -euo pipefail
source ~/.bashrc
mamba activate assembly

SCRIPT_DIR="${SLURM_SUBMIT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
source "${SCRIPT_DIR}/00_breakpoint_validation_config.sh"

bpv_init_dirs
bpv_log "=== STEP 01: Extract INV candidates from DELLY2 + Manta ==="

# ── 1A. Parse DELLY2 INV catalog ────────────────────────────────────────────
bpv_log "--- 1A: Parsing DELLY2 INV catalog ---"

DELLY_PARSED="${BPV_EVIDENCE}/delly_inv_candidates.tsv"

if [[ -f "${DELLY_INV_VCF}" ]]; then
  export DELLY_INV_VCF MIN_DELLY_QUAL MIN_DELLY_PE MAX_INV_SIZE_MB MIN_INV_SIZE_BP
  python3 << 'PYEOF'
import gzip, os

vcf = os.environ["DELLY_INV_VCF"]
out = os.environ.get("DELLY_PARSED", "delly_inv_candidates.tsv")
min_qual = int(os.environ.get("MIN_DELLY_QUAL", "300"))
min_pe = int(os.environ.get("MIN_DELLY_PE", "3"))
max_size = int(os.environ.get("MAX_INV_SIZE_MB", "20")) * 1_000_000
min_size = int(os.environ.get("MIN_INV_SIZE_BP", "5000"))

with gzip.open(vcf, 'rt') as v, open(out, 'w') as o:
    o.write("inv_id\tchrom\tbp1_pos\tbp2_pos\tsvlen_bp\tqual\tpe\tsr\tprecise\tfilter\tcaller\tct\tjunction_type\tcipos\tciend\n")
    n_total = 0; n_pass = 0
    for line in v:
        if line.startswith('#'): continue
        n_total += 1
        p = line.strip().split('\t')
        chrom, pos, inv_id, filt = p[0], int(p[1]), p[2], p[6]
        info = dict(kv.split('=', 1) for kv in p[7].split(';') if '=' in kv)
        flags = set(kv for kv in p[7].split(';') if '=' not in kv)

        qual = float(p[5]) if p[5] != '.' else 0
        end = int(info.get('END', pos))
        svlen = abs(end - pos)
        pe = int(info.get('PE', 0))
        sr = int(info.get('SR', 0))
        precise = 1 if 'PRECISE' in flags else 0
        ct = info.get('CT', '.')
        cipos = info.get('CIPOS', '.')
        ciend = info.get('CIEND', '.')
        srq = info.get('SRQ', '.')       # split-read consensus quality
        consensus = info.get('CONSENSUS', '.')  # breakpoint consensus sequence

        # Count carriers from FORMAT GT
        n_carriers = 0
        if len(p) > 9:
            fmt_keys = p[8].split(':')
            gt_idx = fmt_keys.index('GT') if 'GT' in fmt_keys else 0
            for sd in p[9:]:
                sv = sd.split(':')
                gt = sv[gt_idx] if gt_idx < len(sv) else './.'
                if gt not in ('./.', '0/0', './0', '0/.', '.', '0|0'):
                    n_carriers += 1

        # Junction type for DELLY: CT directly encodes orientation
        # 3to3 = left breakpoint of inversion (reads face inward)
        # 5to5 = right breakpoint of inversion (reads face outward)
        # 3to5 = normal (deletion-like), 5to3 = tandem dup-like
        jtype = "."
        if ct == "3to3":
            jtype = "3to3_left"
        elif ct == "5to5":
            jtype = "5to5_right"
        elif ct == "3to5":
            jtype = "normal_3to5"
        elif ct == "5to3":
            jtype = "tandem_5to3"

        if qual < min_qual or pe < min_pe: continue
        if svlen > max_size or svlen < min_size: continue

        n_pass += 1
        o.write(f"{inv_id}\t{chrom}\t{pos}\t{end}\t{svlen}\t{qual:.0f}\t{pe}\t{sr}\t{precise}\t{filt}\tdelly\t{ct}\t{jtype}\t{cipos}\t{ciend}\n")

    print(f"DELLY INV: {n_total} total → {n_pass} pass filters")
PYEOF
  export DELLY_PARSED
  N_DELLY=$(tail -n +2 "${DELLY_PARSED}" | wc -l)
  bpv_log "  DELLY INV candidates: ${N_DELLY}"
else
  bpv_log "  DELLY INV VCF not found: ${DELLY_INV_VCF} — skipping"
  echo -e "inv_id\tchrom\tbp1_pos\tbp2_pos\tsvlen_bp\tqual\tpe\tsr\tprecise\tfilter\tcaller\tct\tjunction_type" > "${DELLY_PARSED}"
  N_DELLY=0
fi

# ── 1B. Parse Manta INV catalog ─────────────────────────────────────────────
bpv_log "--- 1B: Parsing Manta INV catalog ---"

MANTA_PARSED="${BPV_EVIDENCE}/manta_inv_candidates.tsv"

if [[ -f "${MANTA_INV_VCF}" ]]; then
  export MANTA_INV_VCF MIN_MANTA_QUAL MIN_MANTA_TOTAL_ALT MAX_INV_SIZE_MB MIN_INV_SIZE_BP
  python3 << 'PYEOF'
import gzip, os

vcf = os.environ["MANTA_INV_VCF"]
out = os.environ.get("MANTA_PARSED", "manta_inv_candidates.tsv")
min_qual = int(os.environ.get("MIN_MANTA_QUAL", "50"))
min_total_alt = int(os.environ.get("MIN_MANTA_TOTAL_ALT", "6"))
max_size = int(os.environ.get("MAX_INV_SIZE_MB", "20")) * 1_000_000
min_size = int(os.environ.get("MIN_INV_SIZE_BP", "5000"))

with gzip.open(vcf, 'rt') as v, open(out, 'w') as o:
    o.write("inv_id\tchrom\tbp1_pos\tbp2_pos\tsvlen_bp\tqual\tpe\tsr\tprecise\tfilter\tcaller\tct\tjunction_type\tcipos\tciend\n")
    sample_names = []
    n_total = 0; n_pass = 0

    for line in v:
        if line.startswith('##'): continue
        if line.startswith('#CHROM'):
            sample_names = line.strip().split('\t')[9:]
            continue

        n_total += 1
        p = line.strip().split('\t')
        chrom, pos, inv_id, filt = p[0], int(p[1]), p[2], p[6]
        info = dict(kv.split('=', 1) for kv in p[7].split(';') if '=' in kv)
        flags = set(kv for kv in p[7].split(';') if '=' not in kv)

        qual = float(p[5]) if p[5] != '.' else 0
        end = int(info.get('END', pos))
        svlen = abs(end - pos)
        precise = 1 if 'IMPRECISE' not in flags else 0
        cipos = info.get('CIPOS', '.')
        ciend = info.get('CIEND', '.')

        # Junction type from INV3/INV5 flags
        has_inv3 = 'INV3' in flags
        has_inv5 = 'INV5' in flags
        if has_inv3 and has_inv5:
            jtype = "both"
        elif has_inv3:
            jtype = "3to3_left"
        elif has_inv5:
            jtype = "5to5_right"
        else:
            jtype = "."

        # Aggregate PR/SR across carriers (Manta FORMAT fields)
        fmt_keys = p[8].split(':') if len(p) > 8 else []
        pr_idx = fmt_keys.index('PR') if 'PR' in fmt_keys else -1
        sr_idx = fmt_keys.index('SR') if 'SR' in fmt_keys else -1
        gt_idx = fmt_keys.index('GT') if 'GT' in fmt_keys else 0

        sum_pr = 0; sum_sr = 0
        for sd in p[9:]:
            sv = sd.split(':')
            gt = sv[gt_idx] if gt_idx < len(sv) else './.'
            if gt in ('./.', '0/0', './0', '0/.', '.', '0|0'): continue
            if pr_idx >= 0 and pr_idx < len(sv):
                try: sum_pr += int(sv[pr_idx].split(',')[1])
                except: pass
            if sr_idx >= 0 and sr_idx < len(sv):
                try: sum_sr += int(sv[sr_idx].split(',')[1])
                except: pass

        total_alt = sum_pr + sum_sr

        if qual < min_qual or total_alt < min_total_alt: continue
        if svlen > max_size or svlen < min_size: continue

        n_pass += 1
        # CT equivalent for Manta INV records
        ct = "3to3" if has_inv3 else ("5to5" if has_inv5 else ".")
        o.write(f"{inv_id}\t{chrom}\t{pos}\t{end}\t{svlen}\t{qual:.0f}\t{sum_pr}\t{sum_sr}\t{precise}\t{filt}\tmanta\t{ct}\t{jtype}\t{cipos}\t{ciend}\n")

    print(f"Manta INV: {n_total} total → {n_pass} pass filters")
PYEOF
  export MANTA_PARSED
  N_MANTA=$(tail -n +2 "${MANTA_PARSED}" | wc -l)
  bpv_log "  Manta INV candidates: ${N_MANTA}"
else
  bpv_log "  Manta INV VCF not found: ${MANTA_INV_VCF} — skipping"
  echo -e "inv_id\tchrom\tbp1_pos\tbp2_pos\tsvlen_bp\tqual\tpe\tsr\tprecise\tfilter\tcaller\tct\tjunction_type" > "${MANTA_PARSED}"
  N_MANTA=0
fi

# ── 1C. Merge + deduplicate ────────────────────────────────────────────────
bpv_log "--- 1C: Merging and deduplicating ---"

MERGED_RAW="${BPV_EVIDENCE}/merged_inv_candidates_raw.tsv"
MERGED_DEDUP="${BPV_EVIDENCE}/merged_inv_candidates_dedup.tsv"

# Concatenate (skip headers from second file)
head -1 "${DELLY_PARSED}" > "${MERGED_RAW}"
tail -n +2 "${DELLY_PARSED}" >> "${MERGED_RAW}"
tail -n +2 "${MANTA_PARSED}" >> "${MERGED_RAW}"

N_RAW=$(tail -n +2 "${MERGED_RAW}" | wc -l)
bpv_log "  Raw merged: ${N_RAW} (${N_DELLY} DELLY + ${N_MANTA} Manta)"

# Deduplicate: if DELLY and Manta call the same INV (≥50% reciprocal overlap),
# keep both but mark the concordance. Tag as "both_callers" in a new column.
python3 << 'PYEOF'
import os

raw = os.environ.get("MERGED_RAW", "merged_inv_candidates_raw.tsv")
out = os.environ.get("MERGED_DEDUP", "merged_inv_candidates_dedup.tsv")

rows = []
with open(raw) as f:
    header = f.readline().strip()
    for line in f:
        p = line.strip().split('\t')
        rows.append({
            'inv_id': p[0], 'chrom': p[1], 'bp1': int(p[2]), 'bp2': int(p[3]),
            'svlen': int(p[4]), 'qual': float(p[5]), 'pe': int(p[6]), 'sr': int(p[7]),
            'precise': p[8], 'filter': p[9], 'caller': p[10],
            'ct': p[11], 'junction_type': p[12],
            'cipos': p[13] if len(p) > 13 else '.',
            'ciend': p[14] if len(p) > 14 else '.',
            'cross_caller_match': '.', 'concordance_class': 'single_caller',
        })

# Find overlapping DELLY-Manta pairs
delly_rows = [r for r in rows if r['caller'] == 'delly']
manta_rows = [r for r in rows if r['caller'] == 'manta']

matched_delly = set()
matched_manta = set()

for di, d in enumerate(delly_rows):
    for mi, m in enumerate(manta_rows):
        if d['chrom'] != m['chrom']: continue
        overlap = max(0, min(d['bp2'], m['bp2']) - max(d['bp1'], m['bp1']))
        d_len = d['bp2'] - d['bp1']
        m_len = m['bp2'] - m['bp1']
        if d_len <= 0 or m_len <= 0: continue
        if overlap / d_len >= 0.5 or overlap / m_len >= 0.5:
            d['cross_caller_match'] = m['inv_id']
            d['concordance_class'] = 'both_callers'
            m['cross_caller_match'] = d['inv_id']
            m['concordance_class'] = 'both_callers'
            matched_delly.add(di)
            matched_manta.add(mi)

n_both = len(matched_delly)
n_delly_only = len(delly_rows) - len(matched_delly)
n_manta_only = len(manta_rows) - len(matched_manta)
print(f"Concordance: {n_both} both callers, {n_delly_only} DELLY-only, {n_manta_only} Manta-only")

with open(out, 'w') as o:
    o.write(header + "\tcross_caller_match\tconcordance_class\n")
    for r in rows:
        vals = [r['inv_id'], r['chrom'], str(r['bp1']), str(r['bp2']),
                str(r['svlen']), f"{r['qual']:.0f}", str(r['pe']), str(r['sr']),
                r['precise'], r['filter'], r['caller'], r['ct'], r['junction_type'],
                r['cipos'], r['ciend'],
                r['cross_caller_match'], r['concordance_class']]
        o.write('\t'.join(vals) + '\n')
PYEOF

export MERGED_RAW MERGED_DEDUP
N_DEDUP=$(tail -n +2 "${MERGED_DEDUP}" | wc -l)
bpv_log "  After dedup tagging: ${N_DEDUP} candidates"

# ── 1D. Match to Snake candidates ──────────────────────────────────────────
bpv_log "--- 1D: Matching to Snake inversion candidates ---"
MATCHED="${BPV_EVIDENCE}/matched_delly_snake_candidates.tsv"

python3 << 'PYEOF'
import os

dedup_file = os.environ["MERGED_DEDUP"]
snake_file = os.environ.get("SNAKE_SCORES", "")
out_file = os.environ.get("MATCHED", "matched_candidates.tsv")

# Load candidates
candidates = []
with open(dedup_file) as f:
    header = f.readline().strip()
    for line in f:
        p = line.strip().split('\t')
        candidates.append({
            'inv_id': p[0], 'chrom': p[1], 'bp1': int(p[2]), 'bp2': int(p[3]),
            'svlen': int(p[4]), 'qual': p[5], 'pe': p[6], 'sr': p[7],
            'precise': p[8], 'filter': p[9], 'caller': p[10],
            'ct': p[11], 'junction_type': p[12],
            'cipos': p[13] if len(p) > 13 else '.',
            'ciend': p[14] if len(p) > 14 else '.',
            'cross_caller_match': p[15] if len(p) > 15 else '.',
            'concordance_class': p[16] if len(p) > 16 else '.',
        })

# Load Snake candidates (optional)
snake = []
if snake_file and os.path.exists(snake_file):
    import gzip
    opener = gzip.open if snake_file.endswith('.gz') else open
    with opener(snake_file, 'rt') as f:
        sheader = f.readline().strip().split('\t')
        for line in f:
            p = line.strip().split('\t')
            snake.append(dict(zip(sheader, p)))
    print(f"Snake candidates: {len(snake)}")

# Match
with open(out_file, 'w') as o:
    o.write("inv_id\tchrom\tbp1_pos\tbp2_pos\tsvlen_bp\tqual\tpe\tsr\tprecise\tfilter\t"
            "caller\tct\tjunction_type\tcross_caller_match\tconcordance_class\t"
            "snake_match\tsnake_candidate_id\tsnake_tier\tsnake_score\n")
    for d in candidates:
        best_match = "none"; best_cid = "."; best_tier = "."; best_score = "."
        for s in snake:
            sc = s.get('chrom', s.get('chr', ''))
            if sc != d['chrom']: continue
            ss = int(s.get('start_bp', s.get('start', 0)))
            se = int(s.get('end_bp', s.get('end', 0)))
            overlap = max(0, min(d['bp2'], se) - max(d['bp1'], ss))
            dlen = d['bp2'] - d['bp1']; slen = se - ss
            if dlen > 0 and slen > 0:
                if overlap / dlen >= 0.5 or overlap / slen >= 0.5:
                    best_match = "overlap"
                    best_cid = s.get('candidate_id', s.get('cid', '.'))
                    best_tier = s.get('tier', '.')
                    best_score = s.get('final_score', s.get('score', '.'))
                    break
        o.write(f"{d['inv_id']}\t{d['chrom']}\t{d['bp1']}\t{d['bp2']}\t{d['svlen']}\t"
                f"{d['qual']}\t{d['pe']}\t{d['sr']}\t{d['precise']}\t{d['filter']}\t"
                f"{d['caller']}\t{d['ct']}\t{d['junction_type']}\t"
                f"{d['cross_caller_match']}\t{d['concordance_class']}\t"
                f"{best_match}\t{best_cid}\t{best_tier}\t{best_score}\n")

n_matched = sum(1 for line in open(out_file) if '\toverlap\t' in line)
print(f"Snake matches: {n_matched} / {len(candidates)}")
PYEOF

export SNAKE_SCORES MATCHED
N_MATCHED=$(grep -c 'overlap' "${MATCHED}" || echo 0)
bpv_log "  Snake-matched candidates: ${N_MATCHED}"

# ── 1E. Summary ─────────────────────────────────────────────────────────────
bpv_log "=== STEP 01 COMPLETE ==="
bpv_log "  DELLY candidates:  $(tail -n +2 "${DELLY_PARSED}" | wc -l)"
bpv_log "  Manta candidates:  $(tail -n +2 "${MANTA_PARSED}" | wc -l)"
bpv_log "  Both-caller pairs: $(grep -c 'both_callers' "${MERGED_DEDUP}" || echo 0)"
bpv_log "  Unified table:     ${MATCHED}"
bpv_log "  Snake matches:     ${N_MATCHED}"
