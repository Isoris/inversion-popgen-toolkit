    "q7b_bam_n_split_left_HET":    { "type": "integer", "description": "HET-group carriers with ≥1 split at BP1." },
    "q7b_bam_n_split_right_HET":   { "type": "integer" },
    "q7b_bam_n_split_left_REF":    { "type": "integer", "description": "REF-group count — should be near zero for a real inversion." },
    "q7b_bam_n_split_right_REF":   { "type": "integer" },
    "q7b_bam_n_soft_left_INV":     { "type": "integer", "description": "Carriers with ≥1 breakpoint-proximal soft-clip at BP1 (INV group)." },
    "q7b_bam_n_soft_right_INV":    { "type": "integer" },
    "q7b_bam_n_discord_left_INV":  { "type": "integer", "description": "Carriers with ≥1 discordant FF/RR pair at BP1 (INV group)." },
