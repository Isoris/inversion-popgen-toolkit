{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "existence_layer_a.schema.json",
  "block_type": "existence_layer_a",
  "description": "Local PCA evidence for candidate existence. Twelve D-dimensions measuring sim_mat block properties (contrast, shape, persistence, decay, interior quality, consensus across variants, SV overlap, peel stability, cluster separability, partition entropy, boundary concordance, snake concordance), composite score, provisional tier. This is the Layer A evidence that every candidate has — it's what makes them candidates. Produced by C01a precomputation + C01b cores + C01d scoring.",
  "question": "Q1, Q7",
  "group_validation_required": "NONE",
  "source_script": "C01a + C01b + C01d",
  "required": ["composite_score", "dim_positive", "tier", "shape_class", "span_kb"],
  "properties": {
    "composite_score": { "type": "number", "description": "Weighted sum of D1..D12, range [0,1]" },
    "dim_positive":    { "type": "integer", "description": "Count of D-dimensions exceeding their individual thresholds" },
    "tier":            { "type": "integer", "enum": [1, 2, 3, 4], "description": "Provisional tier from pass-1; rewritten by pass-2 after D8/D11 fill" },
    "d1_block_strength":    { "type": "number" },
    "d2_block_shape":       { "type": "number" },
    "d3_nn_persistence":    { "type": "number" },
    "d4_decay_flatness":    { "type": "number" },
    "d5_interior_quality":  { "type": "number" },
    "d6_consensus":         { "type": "number" },
    "d7_sv_breakpoint":     { "type": "number" },
    "d8_peel_or_hyp":       { "type": "number" },
    "d9_pca_clusters":      { "type": "number" },
    "d10_partition":        { "type": "number" },
    "d11_boundary_concordance": { "type": "number" },
    "d12_snake_concordance":    { "type": "number" },
    "shape_class":        { "type": "string", "enum": ["strong_square", "weak_square", "band", "diffuse", "unclassified"] },
    "landscape_category": { "type": "string" },
    "n_children":         { "type": "integer", "description": "Count of nested sub-candidates" },
    "span_kb":            { "type": "number" },
    "cheat25_status":     { "type": "string", "enum": ["ALIVE", "UNCERTAIN", "WEAK", "DEAD"] },
    "fdr_q_value":        { "type": "number", "description": "BH-corrected q-value from per-window scoring in C01a" },
    "pass_number":        { "type": "integer", "description": "1 for pass-1 skeleton, 2 for post-enrichment re-score" }
  },
  "keys_extracted": [
    { "key": "q1_composite_score",           "from": "composite_score" },
    { "key": "q1_dim_positive",              "from": "dim_positive" },
    { "key": "q1_d01_block_strength",        "from": "d1_block_strength" },
    { "key": "q1_d02_block_shape",           "from": "d2_block_shape" },
    { "key": "q1_d03_nn_persistence",        "from": "d3_nn_persistence" },
    { "key": "q1_d04_decay_flatness",        "from": "d4_decay_flatness" },
    { "key": "q1_d05_interior_quality",      "from": "d5_interior_quality" },
    { "key": "q1_d06_consensus",             "from": "d6_consensus" },
    { "key": "q1_d07_sv_breakpoint",         "from": "d7_sv_breakpoint" },
    { "key": "q1_d08_peel_or_hyp",           "from": "d8_peel_or_hyp" },
    { "key": "q1_d09_pca_clusters",          "from": "d9_pca_clusters" },
    { "key": "q1_d10_partition",             "from": "d10_partition" },
    { "key": "q1_d11_boundary_concordance",  "from": "d11_boundary_concordance" },
    { "key": "q1_d12_snake_concordance",     "from": "d12_snake_concordance" },
    { "key": "q1_shape_class",               "from": "shape_class" },
    { "key": "q1_landscape_category",        "from": "landscape_category" },
    { "key": "q1_n_children",                "from": "n_children" },
    { "key": "q1_span_kb",                   "from": "span_kb" },
    { "key": "q7_tier",                      "from": "tier" },
    { "key": "q7_composite_score",           "from": "composite_score" },
    { "key": "q7_dim_positive",              "from": "dim_positive" },
    { "key": "q7_cheat25_status",            "from": "cheat25_status" },
    { "key": "q7_fdr_q_value",               "from": "fdr_q_value" }
  ]
}
